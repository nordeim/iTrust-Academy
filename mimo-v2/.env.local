# Frontend Environment Variables
# iTrust Academy Frontend Configuration

# API Base URL
# Using relative path to work with Vite proxy
VITE_API_URL=/api/v1

# Stripe Publishable Key (Test Mode)
# Replace with your actual test key from: https://dashboard.stripe.com/test/apikeys
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_51Hxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# App Environment
VITE_APP_ENV=development

# Feature Flags
VITE_ENABLE_PAYMENTS=true
VITE_ENABLE_ENROLLMENT=true
